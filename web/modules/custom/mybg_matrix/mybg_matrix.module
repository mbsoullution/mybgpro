        'video_url' => NULL,
        'poster_url' => NULL,
        'links' => [],
        'show_search' => FALSE,
        'search_action' => NULL,
        'search_placeholder' => NULL,
        'search_query' => '',
      ],
    ],
    'mybg_section_page_header' => [
      'variables' => [
        'title' => '',
        'logo_url' => NULL,
        'poster_url' => NULL,
        'nav_items' => [],
        'links' => [],
        'show_search' => FALSE,
        'search_action' => NULL,
        'search_placeholder' => NULL,
        'search_query' => '',
        'section_description' => NULL,
        'add_url' => NULL,
        'add_label' => '',
