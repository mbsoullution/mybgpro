/**
 * Implements hook_preprocess_node().
 */
function mybg_help_preprocess_node(array &$variables): void {
  $node = $variables['node'];
  if ($node->bundle() !== 'documentation') {
    return;
  }

  $variables['#attached']['library'][] = 'mybg_help/help_ui';

  $breadcrumb = [
    ['title' => 'Центр допомоги', 'url' => '/dopomoga'],
    ['title' => 'Енциклопедія', 'url' => '/encyklopediya'],
  ];

  if ($node->hasField('field_doc_parent') && !$node->get('field_doc_parent')->isEmpty()) {
    $parent = $node->get('field_doc_parent')->entity;
    if ($parent) {
      $breadcrumb[] = ['title' => $parent->label(), 'url' => $parent->toUrl()->toString()];
    }
  }

  $breadcrumb[] = ['title' => $node->label(), 'url' => ''];

  $variables['mybg_doc_breadcrumb'] = $breadcrumb;

  if ($node->hasField('field_doc_module') && !$node->get('field_doc_module')->isEmpty()) {
    $module = $node->get('field_doc_module')->value;
    $variables['mybg_module_help_url'] = '/dopomoga/modul/' . $module;
  }
}

/**
 * Implements hook_form_alter().
 *
 * Contextual field tooltips (ⓘ) on content forms.
 */
function mybg_help_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (!preg_match('/^node_(listing|real_estate|job|organization|event|news)_(edit_)?form$/', $form_id, $m)) {
    return;
  }

  $bundle = $m[1];
  $tips = mybg_help_field_tooltips($bundle);
  $form['#attached']['library'][] = 'mybg_help/help_forms';

  foreach ($tips as $field_name => $tip) {
    if (!isset($form[$field_name])) {
      continue;
    }
    $form[$field_name]['#description'] = ($form[$field_name]['#description'] ?? '') . ' ' . $tip;
    $form[$field_name]['#attributes']['class'][] = 'mybg-field-with-tip';
    $form[$field_name]['#wrapper_attributes']['data-tip'] = strip_tags($tip);
  }
}

