      'field_price' => 'Вкажіть ціну в гривнях або залиште порожнім, якщо домовитесь на місці.',
      'field_phone' => 'Номер для звʼязку. На публічному профілі телефон прихований.',
      'field_address_text' => 'Район або вулиця — допоможе покупцям зорієнтуватися.',
      'field_images' => 'Додайте якісні фото — оголошення з фото отримують більше переглядів.',
    ],
    'real_estate' => [
      'field_re_type' => 'Тип нерухомості: квартира, будинок, ділянка тощо.',
      'field_area_total' => 'Загальна площа в м².',
      'field_price' => 'Ціна в гривнях. Можна позначити «договірна».',
    ],
    'job' => [
      'field_job_type' => 'Вакансія — ви шукаєте працівника. Резюме — ви шукаєте роботу.',
      'field_job_salary' => 'Орієнтовна оплата або «за домовленістю».',
      'field_job_contact' => 'Телефон або месенджер для відгуку.',
    ],
    'organization' => [
      'field_org_type' => 'Категорія бізнесу для каталогу та карти.',
      'field_geolocation' => 'Вкажіть точку на карті — бізнес зʼявиться в розділі «Карта».',
      'field_org_working_hours' => 'Наприклад: Пн–Пт 9:00–18:00, Сб 10:00–15:00.',
    ],
    'event' => [
      'field_event_date' => 'Дата та час початку події.',
      'field_event_location' => 'Адреса або назва місця проведення.',
