  return array_merge($common, $specific[$bundle] ?? []);
}

/**
 * Implements hook_page_attachments().
 */
function mybg_help_page_attachments(array &$attachments): void {
  $account = \Drupal::currentUser();
  if ($account->isAnonymous()) {
    return;
  }

  $needs_tour = FALSE;
  $user = \Drupal\user\Entity\User::load($account->id());
  if ($user && $user->hasField('field_onboarding_done') && (int) $user->get('field_onboarding_done')->value !== 1) {
    $route = \Drupal::routeMatch()->getRouteName();
    if ($route === 'view.frontpage.page_1' || \Drupal::service('path.matcher')->isFrontPage()) {
      $needs_tour = TRUE;
    }
  }

  if ($needs_tour) {
    $attachments['#attached']['library'][] = 'mybg_help/help_ui';
    $attachments['#attached']['drupalSettings']['mybgHelpTour'] = [
      'enabled' => TRUE,
      'steps' => mybg_help_tour_steps(),
      'completeUrl' => '/mybg-help/onboarding-complete',
      'token' => \Drupal::csrfToken()->get('mybg_help_onboarding'),
    ];
  }
}

/**
 * Onboarding tour steps (5–7 steps per spec).
 */
function mybg_help_tour_steps(): array {
  return [
    ['target' => '.mybg-dashboard__search', 'title' => 'Пошук', 'text' => 'Шукайте новини, бізнеси, оголошення та події в одному місці.'],
    ['target' => '.mybg-dashboard__quick-nav', 'title' => 'Розділи', 'text' => 'Основні модулі порталу — новини, робота, бізнес, спільнота.'],
    ['target' => '.mybg-dashboard__cta', 'title' => 'Карта', 'text' => 'Переглядайте бізнеси та місця міста на інтерактивній карті.'],
    ['target' => '.mybg-help-fab', 'title' => 'Довідка', 'text' => 'Кнопка «?» на кожній сторінці — контекстна допомога по модулю.'],
    ['target' => 'a[href="/dopomoga"]', 'title' => 'Центр допомоги', 'text' => 'Енциклопедія, FAQ, місія та roadmap розвитку порталу.'],
    ['target' => '.mybg-create-fab', 'title' => 'Створити', 'text' => 'Додавайте оголошення, вакансії та інший контент для громади.'],
  ];
}
