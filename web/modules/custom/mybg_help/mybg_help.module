<?php

/**
 * @file
 * Help Center integration for «Мій Богуслав».
 */

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Element;
use Drupal\node\NodeInterface;

/**
 * Implements hook_entity_presave().
 *
 * Documentation must not appear on the site front page.
 */
function mybg_help_entity_presave(\Drupal\Core\Entity\EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'documentation') {
    return;
  }
  $entity->setPromoted(FALSE);
  $entity->setSticky(FALSE);
}

