{#
/**
 * @file
 * Theme override for a branding block.
 */
#}
{%
  embed 'radix:block' with {
    block_utility_classes: [
      'block--system-branding',
    ],
  }
%}
  {% block block_content %}
    <a href="{{ path('<front>') }}" class="navbar-brand mybg-branding d-inline-flex align-items-center text-decoration-none">
      {% if site_logo %}
        <img src="{{ site_logo }}" alt="{{ site_name|default('Мій Богуслав') }} logo" class="mybg-branding__logo" width="48" height="48">
      {% endif %}
      {% if site_name %}
        <span class="mybg-branding__name">{{ site_name }}</span>
      {% endif %}
    </a>
  {% endblock %}
{% endembed %}
