{# 
/**
 * @file
 * Site contacts from Config Pages — footer display.
 */
#}
<div class="site-contacts">
  <h3 class="site-contacts__title">{{ 'Контакти'|t }}</h3>
  <ul class="site-contacts__list">
    {% if site_phone %}
      <li class="site-contacts__item site-contacts__item--phone">
        <a href="tel:{{ site_phone_tel }}">{{ site_phone }}</a>
      </li>
    {% endif %}
    {% if site_email %}
      <li class="site-contacts__item site-contacts__item--email">
        <a href="mailto:{{ site_email }}">{{ site_email }}</a>
      </li>
    {% endif %}
    {% if site_telegram %}
      <li class="site-contacts__item site-contacts__item--telegram">{{ site_telegram }}</li>
    {% endif %}
    {% if site_facebook_url %}
      <li class="site-contacts__item site-contacts__item--facebook">
        <a href="{{ site_facebook_url }}" target="_blank" rel="noopener noreferrer">Facebook</a>
      </li>
    {% endif %}
  </ul>
  <div class="site-contacts__developer">
    <p class="site-contacts__developer-line">
      {{ 'Розроблено на'|t }}
      <a href="https://www.drupal.org" target="_blank" rel="noopener noreferrer">Drupal</a>
    </p>
    <p class="site-contacts__developer-line">
      {{ 'Розробник'|t }}: <span class="site-contacts__developer-name">MB_SOUL_Lution</span>
    </p>
  </div>
  {% if mybg_site_name %}
    <p class="site-contacts__copyright">© {{ mybg_copyright_year }} {{ mybg_site_name }}</p>
  {% endif %}
</div>
